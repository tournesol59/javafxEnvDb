<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox fx:id="root" alignment="BOTTOM_CENTER" prefHeight="412.0" prefWidth="526.0" spacing="20.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.eclipse.jxmlsamp.PrimaryChoiceController">
   <children>
      <Label text="Primary View" />
      <ListView fx:id="usersLV" prefHeight="113.0" prefWidth="393.0" />
      <GridPane>
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label fx:id="lblId" text="ID" />
            <Label fx:id="lblFirstName" text="FirstName" GridPane.rowIndex="1" />
            <Label fx:id="lblLastName" text="LastName" GridPane.rowIndex="2" />
            <Label fx:id="lblIdDisp" text="1" GridPane.columnIndex="1" />
            <TextField fx:id="inputFirstName" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <TextField fx:id="inputLastName" GridPane.columnIndex="1" GridPane.rowIndex="2" />
         </children>
      </GridPane>
      <Button fx:id="btnSubmitUser" mnemonicParsing="false" onAction="#addorUpdateUser" text="Submit" />
      <Button fx:id="primaryButton" onAction="#switchToSecondary" text="Switch to Secondary View" />
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
