<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox fx:id="rootPane" alignment="CENTER" prefHeight="139.0" prefWidth="404.0" spacing="20.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.openjfxroot.ui.OrderCellController">
    <children>
       <GridPane>
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label fx:id="lblMessage" text="Message" GridPane.rowIndex="1" />
            <TextField fx:id="messageInput" prefHeight="14.0" prefWidth="191.0" text="MessageDisp" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Label fx:id="lblIndex" text="Index" />
            <Label fx:id="lblUser" text="User" GridPane.rowIndex="2" />
            <ComboBox fx:id="userComboBox" prefWidth="150.0" promptText="comboBoxUser" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <Label fx:id="lblDelivery" text="DeliveryMode" GridPane.rowIndex="3" />
            <Label fx:id="deliveryDisp" text="Delivery" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            <Label fx:id="indexDisp" text="IndexDisp" GridPane.columnIndex="1" />
         </children>
      </GridPane>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
