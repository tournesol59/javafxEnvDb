<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox fx:id="root" alignment="CENTER" prefHeight="416.0" prefWidth="423.0" spacing="20.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
    <children>
      <ListView fx:id="notesLV" editable="true" prefHeight="200.0" prefWidth="200.0" />
        <Label fx:id="secondaryLabel" text="Secondary view" />
      <GridPane>
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label fx:id="lblSelection" text="Property" GridPane.rowIndex="1" />
            <TextField fx:id="messageInput" prefHeight="14.0" prefWidth="191.0" text="Message" GridPane.columnIndex="1" GridPane.rowIndex="1" />
              <Button fx:id="secondaryButton" onAction="#switchToThirdly" text="Switch to third View" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <Button fx:id="submitButton" mnemonicParsing="false" onAction="#submitNoteToList" prefHeight="31.0" prefWidth="170.0" text="Submit" GridPane.rowIndex="2" />
            <Label fx:id="lblIndex" text="index" />
         </children>
      </GridPane>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
