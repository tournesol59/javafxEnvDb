<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox id="root" alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="480.0" prefWidth="640.0" spacing="20.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <ListView fx:id="userLV" prefHeight="200.0" prefWidth="200.0" />
      <GridPane>
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <TextField fx:id="emailInput" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Label fx:id="emailLabel" prefHeight="21.0" prefWidth="239.0" text="Email" GridPane.rowIndex="1" />
            <Label fx:id="lastNameLabel" prefHeight="21.0" prefWidth="219.0" text="Last Name" />
            <TextField fx:id="lastNameInput" GridPane.columnIndex="1" />
            <Label fx:id="postalLabel" prefHeight="21.0" prefWidth="219.0" text="Postal" GridPane.rowIndex="2" />
            <TextField fx:id="postalInput" GridPane.columnIndex="1" GridPane.rowIndex="2" />
         </children>
      </GridPane>
      <Button fx:id="button_add" mnemonicParsing="false" onAction="#addNewUser" text="Add" />
      <Label fx:id="addLabel" text="Select View" />
      <Button fx:id="button_change" onAction="#switchToPrimary" text="Switch to Primary View" />
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
