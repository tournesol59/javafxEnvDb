<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox fx:id="root" alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="480.0" prefWidth="640.0" spacing="20.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.openjfxroot.ui.PrimaryController">
   <children>
      <ListView fx:id="clientLV" prefHeight="200.0" prefWidth="200.0" />
      <GridPane>
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <TextField fx:id="lastNameInput" text="LastName" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Label fx:id="lastNameLabel" prefHeight="21.0" prefWidth="239.0" text="Last Name" GridPane.rowIndex="1" />
            <Label fx:id="firstNameLabel" prefHeight="21.0" prefWidth="219.0" text="First Name" />
            <TextField fx:id="firstNameInput" text="firstName" GridPane.columnIndex="1" />
            <ComboBox fx:id="titleComboBox" prefWidth="150.0" promptText="Title" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <Label fx:id="titleLabel" text="Title" GridPane.rowIndex="2" />
         </children>
      </GridPane>
      <Button fx:id="addCliButton" mnemonicParsing="false" onAction="#addNewClient" text="addButton" />
      <Label fx:id="primaryLabel" text="Primary View" />
      <Button fx:id="primaryButton" onAction="#switchToSecondary" text="Switch to Secondary View" />
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
