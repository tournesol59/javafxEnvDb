import javafx.application.Application;
import javafx.scene.Scene;
import javafx.scene.control.ListView;
import javafx.stage.Stage;

public class ListViewSelectionExample extends Application {

    @Override
    public void start(Stage stage) {
        ListView<String> notesLV = new ListView<>();
        notesLV.getItems().addAll("Note 1", "Note 2", "Note 3");

        // Correct listener for selectedItemProperty
        notesLV.getSelectionModel()
               .selectedItemProperty()
               .addListener((observable, oldValue, newValue) -> {
                   System.out.println("Old: " + oldValue + ", New: " + newValue);
               });

        stage.setScene(new Scene(notesLV, 300, 200));
        stage.show();
    }

    public static void main(String[] args) {
        launch(args);
    }
}

